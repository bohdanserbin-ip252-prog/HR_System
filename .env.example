# =============================================================================
# HR System — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values you need.
# Most variables have sensible defaults for local development.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend Server
# ---------------------------------------------------------------------------

# PORT
# The HTTP port the Rust backend server listens on.
# Default: 3000
PORT=3000

# HR_SYSTEM_DB_PATH
# Absolute or relative path to the SQLite database file.
# Default: backend/hr_system.db
HR_SYSTEM_DB_PATH=backend/hr_system.db

# HR_SYSTEM_FRONTEND_DIST
# Path to the built frontend assets (Vite output directory).
# Default: frontend/dist
HR_SYSTEM_FRONTEND_DIST=frontend/dist

# HR_SYSTEM_COOKIE_SECURE
# Set to 'true' to mark session cookies as Secure (required for HTTPS).
# Default: unset (false)
HR_SYSTEM_COOKIE_SECURE=false

# HR_SYSTEM_COOKIE_SAMESITE
# Cookie SameSite policy: 'lax', 'strict', or 'none'.
# Use 'none' only with cross-site origins and HTTPS.
# Default: lax
HR_SYSTEM_COOKIE_SAMESITE=lax

# HR_SYSTEM_CORS_ORIGIN
# Exact frontend origin for credentialed CORS in split deployments.
# Example: https://app.example.com
# Default: unset (same-origin development)
# HR_SYSTEM_CORS_ORIGIN=https://app.example.com

# HR_SYSTEM_RATE_LIMIT_DISABLED
# Set to 'true' to disable API rate limiting (useful for load testing).
# Default: unset (enabled)
# HR_SYSTEM_RATE_LIMIT_DISABLED=false

# ---------------------------------------------------------------------------
# Email (SMTP)
# ---------------------------------------------------------------------------
# Leave all SMTP variables unset to disable email features.

# SMTP_HOST
# SMTP server hostname.
# Example: smtp.gmail.com
# SMTP_HOST=smtp.gmail.com

# SMTP_PORT
# SMTP server port. Common values: 587 (STARTTLS), 465 (SSL).
# Example: 587
# SMTP_PORT=587

# SMTP_USER
# SMTP authentication username / email address.
# Example: hr@example.com
# SMTP_USER=hr@example.com

# SMTP_PASSWORD
# SMTP authentication password or app-specific password.
# Example: supersecretapppassword
# SMTP_PASSWORD=your-app-password

# SMTP_FROM
# Default "From" address for outgoing emails.
# Example: HR System <hr@example.com>
# SMTP_FROM="HR System <hr@example.com>"

# ---------------------------------------------------------------------------
# Monitoring (Sentry)
# ---------------------------------------------------------------------------

# SENTRY_DSN
# Sentry Data Source Name for error tracking and performance monitoring.
# Example: https://public@o0.ingest.sentry.io/0
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------

# VITE_API_ORIGIN
# External API origin when frontend and backend are deployed separately.
# Must match HR_SYSTEM_CORS_ORIGIN on the backend.
# Include protocol, no trailing slash.
# Example: https://api.example.com
# VITE_API_ORIGIN=https://api.example.com
